# Copie ce fichier en ".env" et colle ta vraie clé API Anthropic.
# Récupère une clé sur https://console.anthropic.com/ (Settings -> API Keys)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Port du serveur chatbot (optionnel, 3001 par défaut)
PORT=3001

# Formulaire Contact -> ta boîte mail, via Formspree (https://formspree.io)
# Crée un formulaire gratuit, copie l'ID de ton endpoint (la partie après /f/ :
# https://formspree.io/f/XXXXXXXX  ->  l'ID est XXXXXXXX) et colle-le ici.
# Laisse vide pour garder le formulaire en mode démo (confirmation sans envoi).
VITE_FORMSPREE_ID=
